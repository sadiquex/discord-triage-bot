# ─── Discord ────────────────────────────────────────────────────────────────
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# ─── Channel IDs ─────────────────────────────────────────────────────────────
# Copy the channel IDs from Discord (right-click channel → Copy Channel ID)
# Enable Developer Mode in Discord settings first
CHANNEL_ISSUE_TRACKER=
CHANNEL_TRIAGED_ISSUES=
CHANNEL_IN_PROGRESS=
CHANNEL_QA_TESTING=
CHANNEL_RESOLVED=
CHANNEL_RELEASE_NOTES=

# ─── Anthropic ───────────────────────────────────────────────────────────────
# console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5441/issues_tracker

# ─── App ─────────────────────────────────────────────────────────────────────
ISSUE_PREFIX=COM
NODE_ENV=development
LOG_LEVEL=info
